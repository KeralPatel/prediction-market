# RPC endpoint (BNB Testnet public RPC or a premium provider like NodeReal/Ankr)
INDEXER_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# MarketFactory contract address (from deployment output)
INDEXER_CONTRACT_ADDR=0x...

# Block number where the contract was deployed (saves scanning from genesis)
INDEXER_FROM_BLOCK=0

# Server port (Render uses 10000 by default; use 3001 locally)
INDEXER_PORT=10000

# PostgreSQL connection string from Supabase
# Found at: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# How often to poll for new blocks (milliseconds)
INDEXER_POLL_MS=12000
